PORT=3000

# osu! oauth — callback url on osu must be exactly this (including /callback)
# https://osu.ppy.sh/home/account/edit
# add both local + cloud run urls in osu if you use both
OSU_CLIENT_ID=12345
OSU_CLIENT_SECRET=your_secret_here
OSU_REDIRECT_URI=http://localhost:3000/auth/osu/callback

# cloud run (production) — use this as OSU_REDIRECT_URI when deployed there
# https://osudatingmeow-git-57346811168.us-east1.run.app/auth/osu/callback
# live site: https://osudatingmeow-git-57346811168.us-east1.run.app
