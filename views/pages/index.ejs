<%- include("../partials/head", { title }) %>

<section class="rr-hero" aria-labelledby="hero-title">
  <h1 id="hero-title" class="rr-hero-title">
    <span class="line1">find your</span>
    <span class="line2">osu soulmate</span>
  </h1>

  <p class="rr-hero-sub">
    a totally serious edating site for osu losers.... who want to find their osu soulmate..... arf meow meow brrr awruff
  </p>

  <div class="rr-hero-cta">
    <% if (me) { %>
      <a class="btn btn-primary" href="/profile">setup your profile</a>
    <% } else { %>
      <a class="btn btn-primary" href="/auth/osu">setup your profile</a>
