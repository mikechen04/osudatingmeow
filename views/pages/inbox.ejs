<%- include("../partials/head", { title }) %>

<section class="card">
  <p class="est">inbox</p>
  <p class="muted" style="margin: 0 0 1rem">people sent these love letters to you</p>

  <% if (!messages || messages.length === 0) { %>
    <p class="empty">no messages yet. ur a chud</p>
  <% } else { %>
    <div class="inbox">
      <% messages.forEach(m => { %>
        <div class="msg <%= m.read_at ? 'read' : 'unread' %>">
          <img
            class="avatar smol"
            src="<%= m.from_avatar_url || 'https://files.catbox.moe/evvmvg.webp' %>"
            alt=""
          />
          <div>
            <div class="msg-top">
              <div class="msg-from">
                <b><%= m.from_username %></b>
                —
                <a class="softlink" href="https://osu.ppy.sh/users/<%= m.from_osu_id %>" target="_blank" rel="noreferrer">osu!</a>
              </div>
              <div class="msg-time"><%= new Date(m.created_at).toLocaleString() %></div>
            </div>
            <div class="msg-body"><%= m.body %></div>

            <form class="replybox" action="/message/send" method="post" style="margin-top: 0.65rem">
              <input type="hidden" name="to_user_id" value="<%= m.from_user_id %>" />
              <input type="hidden" name="redirect_to" value="/inbox" />
              <label class="mini-label">reply</label>
              <textarea name="body" rows="2" maxlength="600" placeholder="type a reply..." required></textarea>
              <button class="btn tiny" type="submit">send</button>
            </form>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</section>

<%- include("../partials/foot") %>
