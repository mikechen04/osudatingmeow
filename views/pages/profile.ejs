<%- include("../partials/head", { title }) %>

<section class="card">
  <p class="est">profile</p>
  <h1 class="h1">make it <em>cute</em></h1>

  <div class="notice">
    <div class="notice-title">18+ only</div>
    <div class="notice-text">
      you must be <b>18 or older</b> to use this site. setting your age below is required.
    </div>
  </div>

  <form action="/profile" method="post" class="form">
    <div class="form-row">
      <label for="age">age</label>
      <input
        id="age"
        name="age"
        type="number"
        min="18"
        max="120"
        value="<%= me && me.age ? me.age : 18 %>"
        required
      />
      <div class="hint">minimum 18. don’t lie or the osu! gods will smite u</div>
    </div>

    <div class="form-row">
      <label for="bio">description</label>
      <textarea
        id="bio"
        name="bio"
        maxlength="400"
        rows="6"
        placeholder="ex: looking for a duo who won't abandon me after 1 bad map..."
        required
      ><%= me && me.bio ? me.bio : "" %></textarea>
      <div class="hint">shown when people browse. keep it light.</div>
    </div>

    <button class="btn" type="submit">save profile</button>
  </form>
</section>

<%- include("../partials/foot") %>
